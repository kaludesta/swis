{
  "name": "temporal-polyfill",
  "version": "0.3.1",
  "title": "Temporal Polyfill",
  "description": "A lightweight polyfill for Temporal, successor to the JavaScript Date object",
  "author": {
    "name": "Adam Shaw",
    "email": "arshaw@users.noreply.github.com",
    "url": "http://arshaw.com/"
  },
  "contributors": [
    {
      "name": "Ishaan Bharal",
      "email": "ishbharal@gmail.com"
    }
  ],
  "license": "MIT",
  "copyright": "2024 Adam Shaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/fullcalendar/temporal-polyfill.git"
  },
  "type": "module",
  "DISABLED_buildConfig": {
    "exports": {
      "./fns/instant": {
        "src": "funcApi/instant"
      },
      "./fns/zoneddatetime": {
        "src": "funcApi/zonedDateTime"
      },
      "./fns/plaindatetime": {
        "src": "funcApi/plainDateTime"
      },
      "./fns/plaindate": {
        "src": "funcApi/plainDate"
      },
      "./fns/plaintime": {
        "src": "funcApi/plainTime"
      },
      "./fns/plainyearmonth": {
        "src": "funcApi/plainYearMonth"
      },
      "./fns/plainmonthday": {
        "src": "funcApi/plainMonthDay"
      },
      "./fns/duration": {
        "src": "funcApi/duration"
      },
      "./fns/now": {
        "src": "funcApi/now"
      }
    }
  },
  "dependencies": {
    "temporal-spec": "0.3.1"
  },
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "module": "./index.js",
  "exports": {
    ".": {
      "module-sync": "./index.js",
      "require": "./index.cjs",
      "import": "./index.js"
    },
    "./impl": {
      "module-sync": "./impl.js",
      "require": "./impl.cjs",
      "import": "./impl.js"
    },
    "./global": {
      "module-sync": "./global.esm.js",
      "require": "./global.cjs",
      "import": {
        "types": "./global.d.ts",
        "default": "./global.esm.js"
      }
    }
  },
  "jsdelivr": "./global.min.js",
  "unpkg": "./global.min.js",
  "sideEffects": [
    "./global.cjs",
    "./global.esm.js",
    "./global.js",
    "./global.min.js"
  ]
}